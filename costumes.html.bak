  <button id="back-to-top" class="back-to-top" aria-label="Retour en haut"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"/></svg></button>

  <script src="script.js"></script>
  <script>function sortProducts(v){const g=document.getElementById('products-grid'),c=Array.from(g.querySelectorAll('.product-card'));c.sort((a,b)=>v==='price-asc'?parseInt(a.dataset.price)-parseInt(b.dataset.price):v==='price-desc'?parseInt(b.dataset.price)-parseInt(a.dataset.price):0);c.forEach(x=>g.appendChild(x));}</script>
